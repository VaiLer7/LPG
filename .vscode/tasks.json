{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Criar pasta executaveis",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "if not exist \"${fileDirname}\\executaveis\" mkdir \"${fileDirname}\\executaveis\""
            ]
        },
        {
            "label": "Compilar C",
            "type": "cppbuild",
            "command": "C:\\MinGW\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\executaveis\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build Completo",
            "dependsOn": [
                "Criar pasta executaveis",
                "Compilar C"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}